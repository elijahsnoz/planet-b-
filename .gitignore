# dependencies
/node_modules

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env
.env*.local
.env

# typescript
*.tsbuildinfo

# SQLite database — generated by `npm run db:seed` (regenerable; not source)
db/*.db
db/*.db-wal
db/*.db-shm

# Large media masters live in cold storage / LFS, not git (GitHub 100MB limit).
# Their provenance + checksums are preserved in archive/manifest.json.
*.mp4
*.mov

# NOTE: image plates, the catalogue PDF, and public/media derivatives ARE committed
# (small, and they are the preserved visual record).

# Runtime picture uploads (admin Media Library) — not committed
public/media/uploads/
