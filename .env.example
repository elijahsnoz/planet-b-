# Planet B — environment variables
# Copy to `.env.local` (gitignored) and fill in real values.
# In production the app REFUSES to start without the secrets marked (required).

# (required in production) Signing secret for admin session JWTs.
# Must be a long, random string of at least 32 characters. Generate one with:
#   openssl rand -base64 48
PLANET_B_SESSION_SECRET=

# (required in production, seed time) Initial super-admin password.
# Used only by `npm run db:seed` / `db:reset` to create the founder account.
# Change it after first login. No insecure default exists in production.
PLANET_B_ADMIN_PASSWORD=

# (optional) Override the seeded super-admin email. Defaults to the founder's.
# PLANET_B_ADMIN_EMAIL=you@example.com

# (optional) Override the SQLite database file path.
# PLANET_B_DB=/absolute/path/to/planet-b.db
