{
  "$description": "Planet B design tokens — single source of truth. Derived from docs/05-design-system.md and docs/06-motion-principles.md. Loosely follows the W3C Design Tokens format ($value/$type). Chrome stays quiet; the artworks supply the color.",
  "color": {
    "ink":     { "$value": "#0B0B0C", "$type": "color", "$description": "primary text on light; base of the dark threshold" },
    "paper":   { "$value": "#F6F3EC", "$type": "color", "$description": "primary warm archival background (not pure white)" },
    "oxblood": { "$value": "#6E1414", "$type": "color", "$description": "the single brand accent — links, mark, focus (from catalogue spine)" },
    "clay":    { "$value": "#7A5C3E", "$type": "color", "$description": "secondary editorial/display header tone (warm brown)" },
    "stone":   { "$value": "#9B978E", "$type": "color", "$description": "captions, metadata, muted borders" },
    "mist":    { "$value": "#E7E2D7", "$type": "color", "$description": "hairlines, fills, subtle surfaces" },
    "signal":  { "$value": "#2FA36B", "$type": "color", "$description": "SEMANTIC ONLY: verified / impact states — never decorative green" }
  },
  "semantic": {
    "bg":          { "$value": "{color.paper}", "$type": "color" },
    "bg-inverse":  { "$value": "{color.ink}", "$type": "color" },
    "text":        { "$value": "{color.ink}", "$type": "color" },
    "text-muted":  { "$value": "{color.stone}", "$type": "color" },
    "accent":      { "$value": "{color.oxblood}", "$type": "color" },
    "border":      { "$value": "{color.mist}", "$type": "color" },
    "verified":    { "$value": "{color.signal}", "$type": "color" },
    "focus-ring":  { "$value": "{color.oxblood}", "$type": "color" }
  },
  "font": {
    "display": { "$value": "Canela, Fraunces, 'Times New Roman', serif", "$type": "fontFamily", "$description": "editorial serif — headlines, artwork titles, pull-quotes" },
    "text":    { "$value": "Söhne, Inter, system-ui, sans-serif", "$type": "fontFamily", "$description": "neutral grotesque — body, UI, metadata" },
    "mono":    { "$value": "'JetBrains Mono', ui-monospace, monospace", "$type": "fontFamily", "$description": "IDs, certificate codes, provenance hashes" }
  },
  "fontSize": {
    "display-1": { "$value": "clamp(2.75rem, 6vw, 7rem)", "$type": "dimension" },
    "display-2": { "$value": "clamp(2rem, 4vw, 3rem)", "$type": "dimension" },
    "h1":        { "$value": "clamp(1.6rem, 2.5vw, 2rem)", "$type": "dimension" },
    "h2":        { "$value": "1.5rem", "$type": "dimension" },
    "h3":        { "$value": "1.25rem", "$type": "dimension" },
    "body":      { "$value": "1.125rem", "$type": "dimension" },
    "small":     { "$value": "0.9rem", "$type": "dimension" },
    "caption":   { "$value": "0.8rem", "$type": "dimension" }
  },
  "lineHeight": {
    "display": { "$value": "1.1", "$type": "number" },
    "body":    { "$value": "1.5", "$type": "number" }
  },
  "measure": { "reading": { "$value": "66ch", "$type": "dimension", "$description": "long-read column width" } },
  "space": {
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "5": { "$value": "24px", "$type": "dimension" },
    "6": { "$value": "32px", "$type": "dimension" },
    "7": { "$value": "48px", "$type": "dimension" },
    "8": { "$value": "64px", "$type": "dimension" },
    "9": { "$value": "96px", "$type": "dimension" },
    "10":{ "$value": "128px", "$type": "dimension" }
  },
  "radius": {
    "none": { "$value": "0", "$type": "dimension" },
    "sm":   { "$value": "2px", "$type": "dimension" },
    "md":   { "$value": "8px", "$type": "dimension" }
  },
  "shadow": {
    "museum-soft": { "$value": "0 1px 2px rgba(11,11,12,.04), 0 8px 24px rgba(11,11,12,.06)", "$type": "shadow", "$description": "soft matting shadow for plates/portraits — never heavy" }
  },
  "container": {
    "default": { "$value": "1200px", "$type": "dimension" },
    "wide":    { "$value": "1440px", "$type": "dimension" }
  },
  "grid": {
    "cols-desktop": { "$value": "12", "$type": "number" },
    "cols-tablet":  { "$value": "6", "$type": "number" },
    "cols-mobile":  { "$value": "4", "$type": "number" }
  }
}
